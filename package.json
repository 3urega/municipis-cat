{
  "name": "catalunya-map",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "icons:pwa": "tsx scripts/generate-pwa-icons.ts",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vitest run",
    "prep": "npm run lint && npm run test && npm run build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:up:with-ollama": "docker compose --profile ollama up -d",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx scripts/seed-municipalities.ts && tsx scripts/seed-dev-superadmin.ts",
    "db:seed:play-review": "tsx scripts/seed-google-play-review-user.ts",
    "storage:recalc": "tsx scripts/recalculate-user-storage.ts",
    "data:comarques": "tsx scripts/build-municipi-comarca-json.ts",
    "data:comarques-geojson": "tsx scripts/build-comarques-geojson.ts",
    "data:visit-static-params": "tsx scripts/write-visit-static-params.ts",
    "build:capacitor": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-capacitor.ps1",
    "build:capacitor:unix": "bash scripts/build-capacitor.sh",
    "cap:sync": "cap sync",
    "android:sync": "cap sync android",
    "android:icons": "capacitor-assets generate --android --iconBackgroundColor \"#ffffff\" --splashBackgroundColor \"#ffffff\" --splashBackgroundColorDark \"#111111\"",
    "android:open": "cap open android",
    "smoke:railway": "node scripts/smoke-railway-api.mjs",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@adplorg/capacitor-in-app-purchase": "^2.0.64",
    "@capacitor-community/admob": "^7.2.0",
    "@capacitor/android": "7.6.1",
    "@capacitor/camera": "^7.0.5",
    "@capacitor/core": "7.6.1",
    "@capacitor/preferences": "^7.0.2",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcryptjs": "^3.0.3",
    "dexie": "^4.3.0",
    "diod": "^3.0.0",
    "dotenv": "^17.3.1",
    "googleapis": "^171.4.0",
    "jose": "^6.2.2",
    "leaflet": "^1.9.4",
    "next": "16.2.1",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "proj4": "^2.20.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "reflect-metadata": "^0.2.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "7.6.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@turf/turf": "^7.3.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/geojson": "^7946.0.16",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.1",
    "webpack": "^5.105.4"
  }
}
