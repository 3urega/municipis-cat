generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MediaType {
  image
  link
}

enum UserPlan {
  FREE
  PREMIUM
}

model Municipality {
  id     String  @id
  name   String
  visits Visit[]

  @@map("municipalities")
}

model User {
  id                      String                  @id @default(cuid())
  name                    String?
  email                   String?                 @unique
  emailVerified           DateTime?               @map("email_verified")
  image                   String?
  passwordHash            String?                 @map("password_hash") @db.Text
  role                    String                  @default("user")
  plan                    UserPlan                @default(FREE)
  storageUsed             BigInt                  @default(0) @map("storage_used")
  rewardAdsWatched        Int                     @default(0) @map("reward_ads_watched")
  rewardUnlockBlocks      Int                     @default(0) @map("reward_unlock_blocks")
  rewardAdsDailyUtcDate   String?                 @map("reward_ads_daily_utc_date")
  rewardAdsDailyCount     Int                     @default(0) @map("reward_ads_daily_count")
  stripeCustomerId        String?                 @unique @map("stripe_customer_id")
  accounts                Account[]
  sessions                Session[]
  visits                  Visit[]
  googlePlaySubscriptions GooglePlaySubscription[]

  @@map("users")
}

model GooglePlaySubscription {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId     String    @map("product_id")
  purchaseToken String    @unique @map("purchase_token") @db.Text
  packageName   String    @map("package_name")
  orderId       String?   @map("order_id")
  expiryTime    DateTime? @map("expiry_time") @db.Timestamptz(6)
  autoRenewing  Boolean   @default(false) @map("auto_renewing")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@map("google_play_subscriptions")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Visit {
  id             String       @id @default(cuid())
  userId         String       @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  municipalityId String
  municipality   Municipality @relation(fields: [municipalityId], references: [id], onDelete: Cascade)
  visitedAt      DateTime     @db.Timestamptz(6)
  notes          String?
  media          Media[]

  @@index([userId])
  @@map("visits")
}

model Media {
  id        String    @id @default(cuid())
  visitId   String
  visit     Visit     @relation(fields: [visitId], references: [id], onDelete: Cascade)
  type      MediaType
  url       String
  sizeBytes Int?      @map("size_bytes")

  @@map("media")
}
