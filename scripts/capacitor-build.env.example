# Plantilla: copia aquest fitxer a l’arrel del repo com a `.env.capacitor.production`
# (no es versiona; està cobert per .gitignore).
#
# Només variables que es fan servir al BUILD de l’app Android (prefix NEXT_PUBLIC_*).
# Són públiques dins l’APK.

# Obligatori perquè l’app parli amb la teva API (Railway, etc.)
NEXT_PUBLIC_API_URL=https://el-teu-servei.up.railway.app

NEXT_PUBLIC_AUTH_ALLOW_CREDENTIALS=true
NEXT_PUBLIC_AUTH_ALLOW_REGISTRATION=true

NEXT_PUBLIC_PRIVACY_POLICY_URL=https://eurega.es/privacy

# AdMob: sense el primer flag sempre s’usa l’ID de prova de Google.
# NEXT_PUBLIC_ADMOB_USE_PRODUCTION_ADS=true
# NEXT_PUBLIC_ADMOB_REWARD_UNIT_ID=ca-app-pub-9479966417463263/3612538029
