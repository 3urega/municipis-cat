# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# PWA (generats per @ducanh2912/next-pwa en build)
/public/sw.js
/public/sw.js.map
/public/workbox-*.js
/public/workbox-*.js.map
/public/fallback-*.js

# production
/build

# uploads llistes (imatges de visites, fora del control de versió)
/uploads

# Capacitor / export estàtic
visit-static-params.json
.api-server-only-stash/

# Windows: flujo alternativo "Zone.Identifier" (ruta con ':' inválida en Windows; rompe clone/checkout)
**/*:Zone.Identifier

# Windows: NUL es dispositivo reservado; no puede existir como archivo (error: invalid path 'NUL')
/NUL

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
