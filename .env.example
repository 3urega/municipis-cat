# Copia a `.env`:  cp .env.example .env  (PowerShell: Copy-Item .env.example .env)

# =============================================================================
# 1. DESARROLLO LOCAL  →  `npm run docker:up`, `npm run dev`
# =============================================================================
DATABASE_URL="postgresql://catalunya:catalunya@127.0.0.1:15432/catalunya_map?schema=public"
AUTH_SECRET="cambia-en-produccion"
AUTH_URL="http://localhost:3000"
# En dev el login por email/contraseña ya está permitido sin flags extra.
# Opcional si usas Prisma Accelerate / migraciones con URL sin pool:
# DIRECT_URL="postgresql://..."

# =============================================================================
# 2. RAILWAY (u otro hosting de la API Node)  →  mismo nombre de variables, valores de prod.
# =============================================================================
# DATABASE_URL=       ← la que te da Railway (Postgres)
# AUTH_SECRET=        ← obligatorio; generar: openssl rand -base64 32
# AUTH_URL=           ← URL pública de tu app Next (https://...)
# AUTH_ALLOW_CREDENTIALS=true     ← habilita POST /api/auth/login
# AUTH_ALLOW_REGISTRATION=true    ← opcional; POST /api/auth/register sin depender solo del anterior
# CORS_ALLOWED_ORIGINS=          ← orígenes del front estático / Capacitor, separados por comas
#                                   (si lo dejas vacío, ya incluye capacitor://localhost por defecto)

# =============================================================================
# 3. ANDROID / CAPACITOR  →  definir ANTES de `npm run build:capacitor` (se “hornan” en el JS)
# =============================================================================
# NEXT_PUBLIC_API_URL=https://tu-api.up.railway.app
# NEXT_PUBLIC_AUTH_ALLOW_CREDENTIALS=true
# NEXT_PUBLIC_AUTH_ALLOW_REGISTRATION=true
# Tras añadir plugins nativos:  npx cap sync android

# --- Raramente necesarias en local ---
# CAPACITOR_STATIC=1              # lo pone el script de build estático
# AUTH_GITHUB_ID / AUTH_GITHUB_SECRET   # solo si activas OAuth GitHub
