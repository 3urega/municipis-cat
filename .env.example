# =============================================================================
# Copia a `.env` (no subir secrets a git):  cp .env.example .env
# PowerShell:  Copy-Item .env.example .env
# =============================================================================
#
# --- MAPA RÁPIDO: dónde va cada cosa en PRODUCCIÓN ---
#
#   ┌─────────────────────────────────────────────────────────────────────────┐
#   │ BACKEND (API Node / Next con rutas /api)                                  │
#   │   → Se define en el PANEL DE VARIABLES del hosting (p. ej. Railway).     │
#   │   → Sin prefijo NEXT_PUBLIC_ (secretos y lógica de servidor).            │
#   │   → Ejemplos: DATABASE_URL, AUTH_SECRET, AUTH_ALLOW_CREDENTIALS, CORS_*    │
#   └─────────────────────────────────────────────────────────────────────────┘
#
#   ┌─────────────────────────────────────────────────────────────────────────┐
#   │ FRONT COMPILADO DENTRO DE LA APP ANDROID (Capacitor)                      │
#   │   → Se define en la MÁQUINA (o CI) que ejecuta `npm run build:capacitor`. │
#   │   → Solo variables NEXT_PUBLIC_* (quedan en el JS de `out/`).             │
#   │   → Son PÚBLICAS: cualquiera puede leerlas al descompilar el APK.         │
#   │   → Ejemplos: NEXT_PUBLIC_API_URL, NEXT_PUBLIC_PRIVACY_POLICY_URL, AdMob │
#   └─────────────────────────────────────────────────────────────────────────┘
#
#   ┌─────────────────────────────────────────────────────────────────────────┐
#   │ DESARROLLO LOCAL (`npm run dev`)                                          │
#   │   → Un solo `.env` en la raíz puede mezclar backend + NEXT_PUBLIC_*       │
#   │     porque todo corre en un proceso; en prod eso se separa como arriba.   │
#   └─────────────────────────────────────────────────────────────────────────┘
#
# =============================================================================


# =============================================================================
# A) DESARROLLO LOCAL  —  `npm run docker:up` + `npm run dev`
# =============================================================================
# Todo en un solo `.env` (servidor + NEXT_PUBLIC_* si quieres probar la UI como en prod).

DATABASE_URL="postgresql://catalunya:catalunya@127.0.0.1:15432/catalunya_map?schema=public"
AUTH_SECRET="cambia-en-produccion"
AUTH_URL="http://localhost:3000"

# En dev el login por email/contraseña ya está permitido sin flags extra.
# Prisma Accelerate: la API necesita Postgres directo, p. ej.:
# DIRECT_URL="postgresql://usuario:pwd@host:5432/db?sslmode=require"
# DATABASE_URL_LOCAL=…   # alias opcional aceptado por el código

# Opcional en local (mismo significado que en Railway):
# AUTH_ALLOW_CREDENTIALS=true
# AUTH_ALLOW_REGISTRATION=true
# CORS_ALLOWED_ORIGINS=http://localhost:3000

# Probar la UI como si fuera build estático (opcional en dev):
# NEXT_PUBLIC_API_URL=http://localhost:3000
# NEXT_PUBLIC_AUTH_ALLOW_CREDENTIALS=true
# NEXT_PUBLIC_AUTH_ALLOW_REGISTRATION=true
# NEXT_PUBLIC_PRIVACY_POLICY_URL=https://eurega.es/privacy


# =============================================================================
# B) SOLO BACKEND  —  Railway (u otro hosting del API Node)
# =============================================================================
# Defínelo en el SERVICIO que ejecuta `npm run start` / Next en modo servidor.
# No confundir con el APK: esto es el proceso Node en la nube.
#
#   DATABASE_URL=postgresql://…          # Postgres (Railway te da la URL)
#   AUTH_SECRET=…                       # openssl rand -base64 32
#   AUTH_URL=https://…                  # URL pública HTTPS del mismo servicio API
#   AUTH_ALLOW_CREDENTIALS=true         # POST /api/auth/login en prod
#   AUTH_ALLOW_REGISTRATION=true        # opcional; POST /api/auth/register
#   CORS_ALLOWED_ORIGINS=https://…      # orígenes del front estático / app; ver middleware
#   AUTH_CROSS_SITE_COOKIES=true        # opcional; flujos web cross-origin (Capacitor usa Bearer)
#   DIRECT_URL=…                        # si Prisma Accelerate: conexión directa a Postgres
#   DATABASE_URL_LOCAL=…                # alias opcional de DATABASE_URL
#
#   GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={…}   # ver sección D
#   GOOGLE_PLAY_PACKAGE_NAME=com.geodiari.app
#
#   ALLOW_PLAN_UPGRADE=true             # opcional; ruta interna de upgrade de plan


# =============================================================================
# C) FRONT COMPILADO (Android / export estático)  —  antes de `npm run build:capacitor`
# =============================================================================
# Defínelo donde GENERAS el bundle (`out/`): tu PC o job de CI.
# No basta con tenerlas en Railway: deben existir EN EL MOMENTO del build;
# quedan incrustadas en el JavaScript (públicas).
#
#   NEXT_PUBLIC_API_URL=https://tu-servicio.up.railway.app
#   NEXT_PUBLIC_AUTH_ALLOW_CREDENTIALS=true
#   NEXT_PUBLIC_AUTH_ALLOW_REGISTRATION=true
#   NEXT_PUBLIC_PRIVACY_POLICY_URL=https://…
#
# AdMob (sin flag de producción siempre se usa el ID de prueba de Google):
#   NEXT_PUBLIC_ADMOB_USE_PRODUCTION_ADS=true
#   NEXT_PUBLIC_ADMOB_REWARD_UNIT_ID=ca-app-pub-…/…
#
# Tras cambios en plugins nativos:  npx cap sync android


# =============================================================================
# D) GOOGLE PLAY — validación de compras en el SERVIDOR (no en el cliente)
# =============================================================================
# Solo en el backend (Railway). El JSON de la cuenta de servicio es secreto.
#
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_PLAY_PACKAGE_NAME=com.geodiari.app


# =============================================================================
# E) SEMBRAR USUARIO DE REVISIÓN PLAY (script manual, una vez; no commitear secrets)
# =============================================================================
# PLAY_REVIEW_SEED_ENABLED=true
# PLAY_REVIEW_USER_EMAIL=play.review@elteudomini.cat
# PLAY_REVIEW_USER_PASSWORD=…
# npm run db:seed:play-review


# =============================================================================
# F) OPCIONALES — build, scripts, OAuth
# =============================================================================
# CAPACITOR_STATIC=1              # lo pone el script de build estático (normalmente no hace falta)
# AUTH_GITHUB_ID=…
# AUTH_GITHUB_SECRET=…
# BASE_URL=https://…              # solo para smoke tests: scripts/smoke-railway-api.mjs
