# Copia a `.env`:  cp .env.example .env  (PowerShell: Copy-Item .env.example .env)

# =============================================================================
# 1. DESARROLLO LOCAL  →  `npm run docker:up`, `npm run dev`
# =============================================================================
DATABASE_URL="postgresql://catalunya:catalunya@127.0.0.1:15432/catalunya_map?schema=public"
AUTH_SECRET="cambia-en-produccion"
AUTH_URL="http://localhost:3000"
# En dev el login por email/contraseña ya está permitido sin flags extra.
#
# Prisma Accelerate (DATABASE_URL=prisma+postgres://…): l’API Next usa @prisma/adapter-pg,
# que necessita Postgres directe. Afegeix una d’aquestes (postgresql:// o postgres://):
# DIRECT_URL="postgresql://usuari:pwd@host:5432/db?sslmode=require"
# o el mateix valor com a DATABASE_URL_LOCAL (nom alternatiu acceptat pel codi).

# =============================================================================
# 2. RAILWAY (u otro hosting de la API Node)  →  mismo nombre de variables, valores de prod.
# =============================================================================
# DATABASE_URL=       ← la que te da Railway (Postgres)
# AUTH_SECRET=        ← obligatorio; generar: openssl rand -base64 32
# AUTH_URL=           ← URL pública de tu app Next (https://...)
# AUTH_ALLOW_CREDENTIALS=true     ← habilita POST /api/auth/login
# AUTH_ALLOW_REGISTRATION=true    ← opcional; POST /api/auth/register sin depender solo del anterior
# CORS_ALLOWED_ORIGINS=          ← orígenes del front estático / Capacitor, separados por comas
#                                   (si lo dejas vacío, ya incluye capacitor://localhost por defecto)

# =============================================================================
# 3. ANDROID / CAPACITOR  →  definir ANTES de `npm run build:capacitor` (se “hornan” en el JS)
# =============================================================================
# NEXT_PUBLIC_API_URL=https://tu-api.up.railway.app
# NEXT_PUBLIC_AUTH_ALLOW_CREDENTIALS=true
# NEXT_PUBLIC_AUTH_ALLOW_REGISTRATION=true
# AdMob — unitat de vídeo recompensat (Console → Ad units → Rewarded). S’embolica al JS del build estàtic.
# NEXT_PUBLIC_ADMOB_REWARD_UNIT_ID=ca-app-pub-TUPUBLISHER/TU_UNITAT_REWARD
# Tras añadir plugins nativos:  npx cap sync android

# =============================================================================
# 4. GOOGLE PLAY BILLING (subscripció Premium Android, validació al servidor)
# =============================================================================
# Només necessari en producció/staging per a POST /api/billing/google-play/verify
# i per revalidar subscripcions a GET /api/auth/me (usuaris amb compra Play).
# Crear compte de servei a Play Console → API access, i enganxar el JSON complet en una línia:
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_PLAY_PACKAGE_NAME=com.geodiari.app

# =============================================================================
# 5. USUARI DE REVISIÓ GOOGLE PLAY (prod, una sola vegada; no commitejar secrets)
# =============================================================================
# PLAY_REVIEW_SEED_ENABLED=true
# PLAY_REVIEW_USER_EMAIL=play.review@elteudomini.cat
# PLAY_REVIEW_USER_PASSWORD=...        # mínim 12 caràcters; mateix valor a Play Console
# npm run db:seed:play-review

# URL pública de la política (obligatòria a Play + enllaç a l’app):
NEXT_PUBLIC_PRIVACY_POLICY_URL=https://eurega.es/privacy

# --- Raramente necesarias en local ---
# CAPACITOR_STATIC=1              # lo pone el script de build estático
# AUTH_GITHUB_ID / AUTH_GITHUB_SECRET   # solo si activas OAuth GitHub
